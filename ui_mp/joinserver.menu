		// Server list box - golden transparent overlay, scroll focus
		itemDef 
        {
            name serverlist
            rect 19 145 600 302
            type ITEM_TYPE_LISTBOX
            style WINDOW_STYLE_FILLED
            elementwidth 120
            elementheight 15
            textfont	UI_FONT_NORMAL
            textalign 1
            textalignx 1
            textaligny -1
            textscale GLOBAL_TEXTSCALE1	
            elementtype LISTBOX_TEXT
            feeder FEEDER_SERVERS		
            forecolor 1 1 1 1
            backcolor 0.08 0.10 0.25 0.85
            outlinecolor 0.5 0.6 0.8 0.4
            visible 1
            columns	6		2		20		20
                                21		40		40        
                                286		40		20  
                                400		5		10 
                                464		20		10
                                548		20		20	
                    
            doubleClick { uiScript JoinServer }
        }

		// --- Column header sort tabs (each with unique text color) ---

		// Password (icon)
		itemDef 
		{
			name password
			group grpTabs
			type ITEM_TYPE_BUTTON
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .1 .1 .1 .25	
			rect 20 130 21 15
			forecolor 1 1 1 1
			backcolor OPTIONS_HEADING_JOIN_COLOR
			visible 1 
			action 
			{
				play "mouse_click" ; 
				uiScript ServerSort 0 ;
				setitemcolor grpTabs backcolor .3 .5 .2 .3 ; 
				setitemcolor password backcolor .1 .2 .37 1 ; 
				setitemcolor grpColumn backcolor 0 0 0 0 ; 
				setitemcolor passwordColumn backcolor 0 0 0.4 .15 
			}
			mouseEnter { show message_sort ; setitemcolor passwordColumn bordercolor 1 1 1 1 ; play "mouse_over" }
			mouseExit { hide message_sort ; setitemcolor passwordColumn bordercolor 0.7 0.7 0.7 0.7 }  
		}
		itemDef 
		{
			name passwordicon
			style WINDOW_STYLE_SHADER
			rect 23 131 16 16
			background "ui_mp/assets/hud@locked.tga"
			visible 1
			decoration
		}

