		// Join Server button - bright green
		itemDef {
			name			accept
			text			"@MENU_JOIN_SERVER"
		 	type			1
			textfont		UI_FONT_NORMAL
			style			UI_BUTTON_STYLE	
			textstyle		UI_BUTTON_TEXT_STYLE
			rect			510 453 90 14 
			textalign		1
			textscale		GLOBAL_TEXTSCALE1		
			textalignx		45
			textaligny		11
			forecolor		1 1 1 1
			visible			1
			border			1
			bordercolor		0 0.9 0 0.8
			backcolor		0 0.4 0.1 0.9
			
			
			mouseEnter		{  setitemcolor accept backcolor 0.1 0.7 0.2 1 ; play "mouse_over"}
			mouseExit		{  setitemcolor accept backcolor 0 0.4 0.1 0.9 }
		     	action {
				play "mouse_click";
				close createserver ;
				close joinserver ;
				close multi_menu ;
				close main;
				uiScript JoinServer;
			}	
	    	}

	}


	// Delete favorite confirmation popup - colored
	menuDef {
		name del_fav_popmenu
		visible 0
		fullscreen 0
		rect 200 220 250 80
		focusColor UI_FOCUS_COLOR

		backcolor 0.02 0.03 0.08 0.95
		border 1
		bordercolor .5 .5 .5 .5
		style WINDOW_STYLE_FILLED
		popup
		onESC {
			close del_fav_popmenu;
			open joinserver;
			}

		itemDef {
			name confirm
			text "@MENU_DEL_SEL_FAVORITE"
			style 0
			textscale .24
			textstyle 3
			rect 0 0 240 60
			textalign ITEM_ALIGN_CENTER
			textalignx 125
			textaligny 20
			decoration
			forecolor 1 0.9 0.2 1
			visible 1
			}

		itemDef {
			name overwrite_yes
			text "@MENU_YES"
			type 1
			textfont UI_FONT_NORMAL
			textscale .25
			textstyle		UI_BUTTON_TEXT_STYLE
			style			UI_BUTTON_STYLE
			rect 65 35 45 24
			textalign ITEM_ALIGN_CENTER
			textalignx 21
			textaligny 16
			border			1
			bordercolor		0 0.8 0 0.8
			backcolor		0 0.3 0.1 0.9
			forecolor		1 1 1 1
			visible 1
			action { 
				play "mouse_click"; 
				uiScript	DeleteFavorite ;
				uiScript	UpdateFilter
				close		del_fav_popmenu;
				open joinserver;
			}
			mouseEnter { setitemcolor overwrite_yes backcolor 0.1 0.6 0.2 1 
			play "mouse_over"} 
			mouseExit { setitemcolor overwrite_yes backcolor 0 0.3 0.1 0.9 } 		
			}

		itemDef {
			name overwrite_no
			text "@MENU_NO"
			type 1
			textfont UI_FONT_NORMAL
			textscale .25
			textstyle		UI_BUTTON_TEXT_STYLE
			style			UI_BUTTON_STYLE
			rect 144 35 45 24
			textalign ITEM_ALIGN_CENTER
			textalignx 21
			textaligny 16
			border			1
			bordercolor		0.5 0.5 0.5 0.6
			backcolor		0.1 0.1 0.2 0.85
			forecolor		1 1 1 1
			visible 1
			action { 
				play "mouse_click";
				close del_fav_popmenu;
				open joinserver;
			}
			mouseEnter { setitemcolor overwrite_no backcolor 0.25 0.25 0.4 1 
			play "mouse_over"} 
			mouseExit { setitemcolor overwrite_no backcolor 0.1 0.1 0.2 0.85 } 		
			}
	}

