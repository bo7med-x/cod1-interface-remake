#include "ui_mp/menudef.h"

#define GLOBAL_TEXTSCALE1	0.25
#define GLOBAL_TEXTSCALE2	0.3
#define GLOBAL_TEXTSCALE3	0.4

// Navy header background for tabs
#define OPTIONS_HEADING_JOIN_COLOR	0.08 0.12 0.35 0.7
{
	\\ Server Join \\

	menuDef 
	{
		name			"joinserver"
		fullscreen		1
		rect			1 0 640 480
		focusColor UI_FOCUS_COLOR
		style			1

		onOpen 
		{		
			uiScript UpdateFilter ;
			hide accept_alt ; 
			show accept ;
			hide back_alt ;
			show back ;
			hide grpmessage
			setfocus serverlist
		}
	
		onEsc 
		{
			uiScript closeJoin
			close joinserver ;
			open main
		}
	
		#include "ui_mp/menu_background.menu"

		// Main window - deep navy
		itemDef 
		{
			name window
			group grpSystembutton
			rect 19 129 600 340	
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .5 .5 .5 .5
			forecolor 1 1 1 1
			backcolor 0.02 0.03 0.08 0.92
			visible 1
			decoration
		}
		// Top-left small window
		itemDef 
		{
			name window
			group grpSystembutton
			rect 19 5 360 125	
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .5 .5 .5 .5
			forecolor 1 1 1 1
			backcolor 0.02 0.03 0.08 0.92
			visible 1
			decoration
		}
		// Title "Join Server" - gold
		itemDef 
		{
			name window
			text "@MENU_JOIN_SERVER"
			textscale .45
			textstyle ITEM_TEXTSTYLE_SHADOWED
			align 1
			group grpSystembutton
			rect 45 15 52 25	
			style 0
			textalignx 100		
			textaligny 17
			border 0
			bordercolor .5 .5 .5 .5
			forecolor 1 0.9 0.2 1
			backcolor 0 0 0 .7
			visible 1
			decoration
		}

		// Source selector (Internet/Local/Favorites) - cyan
		itemDef 
		{
			name sourcefield
			style WINDOW_STYLE_FILLED	
			textfont	UI_FONT_NORMAL
			ownerdraw UI_NETSOURCE
			rect 21 53 240 15 
			textstyle 3
			textalign ITEM_ALIGN_RIGHT		
			textalignx 29     
			textaligny 12    
			textstyle 3
			textscale GLOBAL_TEXTSCALE1     
			forecolor 0 1 1 1
			backcolor 0.04 0.06 0.12 0.6
			visible 1 
			action { play "mouse_click" }
			mouseEnter { show message_source ; play "mouse_over" }
			mouseExit { hide message_source }
		}

		// Connection speed - light blue
		itemDef 
		{
			name dataratesetting		
			type ITEM_TYPE_MULTI
			text "@MENU_CONNECTION"
			cvar "rate"
			cvarFloatList { "@MENU_288K" 2500 "@MENU_336K" 3000 "@MENU_56K" 4000 "@MENU_ISDN" 5000 "@MENU_LAN_CABLE_XDSL" 25000  }
			rect 21 75 240 15
			textalign ITEM_ALIGN_RIGHT
			textalignx 75
			textaligny 12
			textstyle 3
			textfont	UI_FONT_NORMAL
			textscale GLOBAL_TEXTSCALE1
			style WINDOW_STYLE_FILLED
			backcolor 0.04 0.06 0.12 0.6           
			forecolor 0.4 0.8 1 1
			visible 1 
			mouseenter { play "mouse_over" }
			action { play "mouse_click"; uiScript update ui_setRate }
	   	}
	
		// Game type filter - magenta
		itemDef 
		{
			name gametypefield
			style WINDOW_STYLE_FILLED	
			textstyle 3
			text "@MENU_GAME_TYPE"
			ownerdraw UI_JOINGAMETYPE
			textfont	UI_FONT_NORMAL
			rect 21 95 240 15
